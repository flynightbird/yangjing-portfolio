{
  "name": "yangjing-call-agent-case-study",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/validate-publication.mjs --mode=source && next build && node scripts/validate-publication.mjs --mode=output",
    "build:framework": "next build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:export": "node --test tests/export/*.test.mjs",
    "test:e2e:export": "playwright test --config=playwright.export.config.mjs",
    "test:visual": "playwright test tests/visual",
    "validate:content": "node scripts/validate-content.mjs",
    "prepare:assets": "node scripts/prepare-call-agent-assets.mjs",
    "prepare:xuelang": "node scripts/prepare-xuelang-assets.mjs",
    "generate:meeting-evidence": "node scripts/generate-meeting-static-evidence.mjs",
    "prepare:meeting:static": "npm run generate:meeting-evidence && node scripts/prepare-meeting-assets.mjs --static-only",
    "prepare:meeting": "npm run generate:meeting-evidence && node scripts/prepare-meeting-assets.mjs",
    "prepare:convo-ai": "node scripts/prepare-convo-ai-assets.mjs",
    "pdf:xuelang": "npm run build:framework && node scripts/generate-xuelang-pdfs.mjs",
    "verify:xuelang-pdf": "node --test tests/export/xuelang-pdf.test.mjs",
    "sync:stt": "node scripts/sync-stt-demo.mjs",
    "capture:aidx": "node scripts/capture-aidx-showcase.mjs",
    "verify:export": "npm run build:framework && npm run test:export && npm run test:e2e:export",
    "verify:publish": "npm run lint && npm test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "acorn": "8.17.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "sharp": "0.35.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@fontsource/archivo-black": "5.2.8",
    "@fontsource/dm-mono": "5.2.7",
    "@fontsource/geist": "5.2.8",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/libre-franklin": "5.2.8",
    "@fontsource/noto-sans-sc": "5.2.9",
    "@fontsource/outfit": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.10",
    "gsap": "^3.15.0",
    "lucide-react": "1.24.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "zod": "4.4.3"
  }
}
